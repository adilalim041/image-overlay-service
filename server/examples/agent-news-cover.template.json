{
  "id": "agent-news-cover",
  "name": "Agent News Cover",
  "width": 1080,
  "height": 1350,
  "layers": [
    {
      "id": "background",
      "name": "Background Image",
      "type": "image",
      "x": 0,
      "y": 0,
      "width": 1080,
      "height": 1350,
      "src": "{{imageUrl}}",
      "fit": "cover",
      "visible": true,
      "opacity": 100
    },
    {
      "id": "dark-grade",
      "name": "Dark Grade",
      "type": "rect",
      "x": 0,
      "y": 0,
      "width": 1080,
      "height": 1350,
      "fillType": "gradient",
      "gradientDirection": "vertical",
      "gradientFrom": "#00000022",
      "gradientTo": "#000000dd",
      "visible": true,
      "opacity": 100
    },
    {
      "id": "source-pill",
      "name": "Source Pill",
      "type": "rect",
      "x": 60,
      "y": 78,
      "width": 290,
      "height": 58,
      "fill": "#ffffff",
      "radius": 29,
      "visible": true,
      "opacity": 92
    },
    {
      "id": "source-label",
      "name": "Source Label",
      "type": "text",
      "x": 84,
      "y": 92,
      "width": 244,
      "height": 34,
      "text": "{{source}}",
      "fontSize": 28,
      "fontFamily": "bold",
      "fill": "#101010",
      "align": "center",
      "lineHeight": 1,
      "visible": true,
      "opacity": 100
    },
    {
      "id": "headline",
      "name": "Headline",
      "type": "text",
      "x": 60,
      "y": 790,
      "width": 960,
      "height": 330,
      "text": "{{headline}}",
      "fontSize": 88,
      "fontFamily": "bold",
      "fill": "#ffffff",
      "align": "left",
      "lineHeight": 1.05,
      "textTransform": "uppercase",
      "visible": true,
      "opacity": 100
    },
    {
      "id": "subtitle",
      "name": "Subtitle",
      "type": "text",
      "x": 62,
      "y": 1148,
      "width": 840,
      "height": 120,
      "text": "{{headline2}}",
      "fontSize": 44,
      "fontFamily": "regular",
      "fill": "#f8d34a",
      "align": "left",
      "lineHeight": 1.15,
      "visible": true,
      "opacity": 100
    }
  ]
}
