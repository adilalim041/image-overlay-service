# Server
PORT=3000
CLIENT_DIST_PATH=../client/dist
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth
# Generate with: openssl rand -hex 32
TEMPLATE_API_KEY=replace-with-template-api-key
TEMPLATE_ADMIN_USERNAME=admin
TEMPLATE_ADMIN_PASSWORD=replace-with-admin-password
# Local development only. Never enable in production.
ALLOW_UNAUTHENTICATED_TEMPLATE_API=false

# Storage
# Configure Supabase storage variables in Railway/local env only.

# Error monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/...
